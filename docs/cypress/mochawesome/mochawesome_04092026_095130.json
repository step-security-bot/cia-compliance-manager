                {
                  "title": "should not display any CSP violations in console",
                  "fullTitle": "Security Headers Security Headers Comprehensive Check should not display any CSP violations in console",
                  "timedOut": null,
                  "duration": 2327,
                  "state": "passed",
                  "speed": "fast",
                  "pass": true,
                  "fail": false,
                  "pending": false,
                  "context": null,
                  "code": "// This test needs to be run separately to capture violations during initial page load\ncy.visit(\"/\", {\n    onBeforeLoad(win) {\n        // Track CSP violations\n        let cspViolations = 0;\n        win.addEventListener(\"securitypolicyviolation\", (e) => {\n            cspViolations++;\n            // Log violation details for debugging\n            const { violatedDirective, blockedURI } = e;\n            cy.log(`CSP Violation: ${violatedDirective} - ${blockedURI || \"inline\"}`);\n        });\n        // Store reference for later assertion\n        win.cspViolations =\n            () => cspViolations;\n    },\n});\ncy.ensureAppLoaded();\n// Wait a moment for any violations to be reported\ncy.wait(1000);\n// Verify no violations occurred during page load\ncy.window().then((win) => {\n    const violations = win.cspViolations();\n    expect(violations).to.equal(0, \"No CSP violations detected\");\n});",
                  "err": {},
                  "uuid": "d72dc634-d8e7-46ae-af48-eb6037209c35",
                  "parentUUID": "88a02afd-7c3b-4a9a-9c06-9c2a52fdb0bc",
