              "beforeHooks": [],
              "afterHooks": [],
              "tests": [
                {
                  "title": "should not have X-Frame-Options as meta tag (HTTP header only)",
                  "fullTitle": "Security Headers Clickjacking Protection should not have X-Frame-Options as meta tag (HTTP header only)",
                  "timedOut": null,
                  "duration": 468,
                  "state": "passed",
                  "speed": "fast",
                  "pass": true,
                  "fail": false,
                  "pending": false,
                  "context": null,
                  "code": "// X-Frame-Options can only be set via HTTP headers, not meta tags\n// Verify it is NOT present as a meta tag (which would be ignored by browsers)\ncy.get('meta[http-equiv=\"X-Frame-Options\"]').should(\"not.exist\");",
                  "err": {},
                  "uuid": "204f15d1-99cb-48ed-8c3b-0b5df4172ebd",
                  "parentUUID": "4f6587bd-b834-48ca-9829-e198129e281a",
                  "isHook": false,
                  "skipped": false
                },
                {
                  "title": "should enforce clickjacking protection via HTTP response headers",
                  "fullTitle": "Security Headers Clickjacking Protection should enforce clickjacking protection via HTTP response headers",
                  "timedOut": null,
                  "duration": 586,
                  "state": "passed",
                  "speed": "fast",
                  "pass": true,
                  "fail": false,
                  "pending": false,
                  "context": null,
                  "code": "// Verify X-Frame-Options and frame-ancestors are delivered as HTTP headers\n// (configured in vite.config.ts for dev, CloudFront for production)\ncy.request(\"/\").then((response) => {\n    const headers = response.headers;\n    // X-Frame-Options must be DENY via HTTP header\n    expect(headers).to.have.property(\"x-frame-options\");\n    expect(headers[\"x-frame-options\"]).to.match(/deny/i, \"X-Frame-Options HTTP header should be DENY\");\n    // CSP frame-ancestors must be set to 'none' in the HTTP header to prevent framing\n    expect(headers).to.have.property(\"content-security-policy\");\n    const cspHeader = headers[\"content-security-policy\"];\n    expect(cspHeader).to.include(\"frame-ancestors 'none'\", \"CSP HTTP header should set frame-ancestors to 'none' for clickjacking protection\");\n});",
                  "err": {},
                  "uuid": "8281ea33-0ebe-4188-aa24-43aba86628b8",
                  "parentUUID": "4f6587bd-b834-48ca-9829-e198129e281a",
                  "isHook": false,
                  "skipped": false
                }
