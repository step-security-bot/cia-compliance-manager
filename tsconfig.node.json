{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "target": "ES2025"
  },
  "include": [
    "vite.config.ts",
    "cypress.config.ts",
    "cypress/support/plugins/**/*.ts",
    "cypress/tasks/**/*.ts"
  ]
}
